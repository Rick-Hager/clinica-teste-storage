---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<Base
  title="Telemedicina — Clínica Teste Storage | São Paulo"
  description="Teleconsulta médica segura e regularizada pela Clínica Teste Storage. Atendimento de qualidade no conforto da sua casa."
>
  <PageHero
    overline="Serviço"
    title="Telemedicina"
    subtitle="Atendimento médico de qualidade onde quer que você esteja — seguro, regularizado e tão eficaz quanto a consulta presencial para os casos indicados."
  />

  <section class="section">
    <div class="container service-layout">
      <div class="service-body">

        <div class="service-block">
          <h2>O que é</h2>
          <p>A telemedicina permite que você seja atendido por um dos nossos médicos por videochamada, sem precisar sair de casa. É regulamentada pela Lei nº 14.510/2022 e pelos conselhos médicos, com todos os direitos e responsabilidades de uma consulta presencial.</p>
        </div>

        <div class="service-block">
          <h2>Ideal para</h2>
          <ul class="service-list">
            <li>Consultas de retorno e acompanhamento de exames</li>
            <li>Renovação e revisão de prescrições de rotina</li>
            <li>Dúvidas pós-consulta que não exigem exame físico</li>
            <li>Pacientes com dificuldade de locomoção ou agenda muito restrita</li>
            <li>Acompanhamento de condições crônicas estáveis</li>
          </ul>
        </div>

        <div class="service-block">
          <h2>Como funciona</h2>
          <ol class="service-steps">
            <li>Agende sua teleconsulta pelo site ou WhatsApp.</li>
            <li>Receba o link de acesso por WhatsApp antes da consulta.</li>
            <li>Conecte-se do celular, tablet ou computador no horário marcado.</li>
            <li>O médico realiza a consulta por videochamada com total privacidade.</li>
            <li>Receita e orientações são enviadas digitalmente com validade legal.</li>
          </ol>
        </div>

        <div class="service-block">
          <h2>Tecnologia utilizada</h2>
          <p class="placeholder-text">Plataforma a informar — a ser preenchido quando a clínica definir a solução de telemedicina adotada.</p>
        </div>

        <div class="service-block service-block--privacy">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          <div>
            <h3>Privacidade e segurança</h3>
            <p>Todas as consultas são realizadas em ambiente criptografado. Seus dados de saúde são protegidos conforme a Lei Geral de Proteção de Dados (LGPD).</p>
          </div>
        </div>

      </div>

      <aside class="service-sidebar">
        <div class="sidebar-card">
          <h3>Agende sua Teleconsulta</h3>
          <p>Atendimento médico de qualidade no conforto da sua casa.</p>
          <a href="/contato" class="btn btn-primary" style="width:100%;justify-content:center;">Agendar Teleconsulta</a>
          <a href="https://wa.me/5511999999999" class="btn btn-whatsapp" style="width:100%;justify-content:center;" target="_blank" rel="noopener">Chamar no WhatsApp</a>
        </div>
        <div class="sidebar-links">
          <p class="sidebar-links__title">Outros serviços</p>
          <a href="/servicos/consulta-geral">Consulta de Clínica Geral</a>
          <a href="/servicos/check-up-preventivo">Check-up Preventivo</a>
          <a href="/servicos/acompanhamento">Acompanhamento de Saúde</a>
          <a href="/servicos/exames-e-laudos">Exames e Laudos</a>
        </div>
      </aside>
    </div>
  </section>

  <CTABanner
    title="Consulte sem sair de casa"
    text="Segura, regularizada e conveniente. Agende sua teleconsulta com a Clínica Teste Storage."
    primaryLabel="Agendar Teleconsulta"
    primaryHref="/contato"
  />
</Base>

<style>
  .service-layout { display: grid; grid-template-columns: 1fr 320px; gap: var(--space-12); align-items: flex-start; }
  .service-body { display: flex; flex-direction: column; gap: var(--space-10); }
  .service-block h2 { font-family: var(--font-display); font-size: var(--text-h3); color: var(--color-primary); margin-bottom: var(--space-4); }
  .service-block h3 { font-size: var(--text-h4); font-weight: var(--font-semibold); color: var(--color-gray-900); margin-bottom: var(--space-2); }
  .service-block p { color: var(--color-gray-600); line-height: var(--leading-relaxed); }
  .service-list { color: var(--color-gray-600); line-height: var(--leading-relaxed); padding-left: var(--space-6); list-style: disc; display: flex; flex-direction: column; gap: var(--space-2); }
  .service-steps { color: var(--color-gray-600); line-height: var(--leading-relaxed); padding-left: var(--space-6); list-style: decimal; display: flex; flex-direction: column; gap: var(--space-2); }
  .service-block--privacy { display: flex; gap: var(--space-4); background: var(--color-accent-light); border-radius: var(--radius-lg); padding: var(--space-6); color: var(--color-accent); align-items: flex-start; }
  .service-block--privacy svg { flex-shrink: 0; margin-top: 2px; }
  .service-block--privacy h3 { color: var(--color-gray-900); }
  .service-sidebar { position: sticky; top: 90px; display: flex; flex-direction: column; gap: var(--space-6); }
  .sidebar-card { background: var(--color-white); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-md); display: flex; flex-direction: column; gap: var(--space-4); border-top: 3px solid var(--color-primary); }
  .sidebar-card h3 { font-size: var(--text-h4); font-weight: var(--font-semibold); color: var(--color-gray-900); }
  .sidebar-card p { font-size: var(--text-body-sm); color: var(--color-gray-600); }
  .sidebar-links { background: var(--color-gray-100); border-radius: var(--radius-lg); padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-2); }
  .sidebar-links__title { font-size: var(--text-caption); font-weight: var(--font-bold); letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--color-gray-600); margin-bottom: var(--space-2); }
  .sidebar-links a { font-size: var(--text-body-sm); color: var(--color-primary); padding: var(--space-2) var(--space-3); border-radius: var(--radius-sm); transition: background-color var(--duration-fast) var(--ease-out); }
  .sidebar-links a:hover { background-color: var(--color-primary-light); }
  @media (max-width: 900px) { .service-layout { grid-template-columns: 1fr; } .service-sidebar { position: static; } }
</style>
