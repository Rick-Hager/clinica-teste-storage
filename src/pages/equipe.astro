---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Base
  title="Nossa Equipe Médica — Clínica Teste Storage | São Paulo"
  description="Conheça os médicos e profissionais da Clínica Teste Storage. Formação, especialidades e CRM de cada profissional."
>
  <PageHero
    overline="Equipe"
    title="Nossa Equipe"
    subtitle="Profissionais que combinam excelência técnica com atenção genuína a cada paciente."
  />

  <section class="section">
    <div class="container">

      <div class="notice-banner">
        <strong>Dados da equipe em preenchimento:</strong> os cards completos de cada profissional (foto, nome, CRM, RQE e especialidade) serão publicados em conformidade com a Resolução CFM nº 2.336/2023.
      </div>

      <p class="team-intro">Nossa equipe é formada por médicos com sólida formação e compromisso genuíno com cada paciente. Aqui você sempre sabe quem está te atendendo e quais são as qualificações de cada profissional.</p>

      <div class="grid-3">
        {[1, 2, 3].map((_, i) => (
          <article class="team-card">
            <div class="team-card__photo" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div class="team-card__info">
              <h2 class="team-card__name placeholder-text">Dr(a). A confirmar</h2>
              <p class="team-card__specialty badge badge-teal">Especialidade a confirmar</p>
              <dl class="team-card__credentials">
                <div>
                  <dt>CRM</dt>
                  <dd class="placeholder-text">A preencher</dd>
                </div>
                <div>
                  <dt>RQE</dt>
                  <dd class="placeholder-text">A preencher</dd>
                </div>
                <div>
                  <dt>Formação</dt>
                  <dd class="placeholder-text">A preencher</dd>
                </div>
              </dl>
              <p class="team-card__bio placeholder-text">Breve bio do profissional — a preencher com formação, trajetória e especialização.</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <CTABanner
    title="Conheça nossa equipe pessoalmente"
    text="Agende uma consulta e experimente o atendimento humanizado da Clínica Teste Storage."
    primaryLabel="Agendar Consulta"
    primaryHref="/contato"
  />
</Base>

<style>
  .team-intro {
    font-size: var(--text-body-lg);
    color: var(--color-gray-600);
    line-height: var(--leading-loose);
    max-width: 700px;
    margin: 0 auto var(--space-10);
    text-align: center;
  }
  .team-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out);
  }
  .team-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
  .team-card__photo {
    background: var(--color-gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-10) 0;
    color: var(--color-gray-400);
  }
  .team-card__info { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }
  .team-card__name { font-size: var(--text-h4); font-weight: var(--font-semibold); }
  .team-card__specialty { align-self: flex-start; }
  .team-card__credentials { display: flex; flex-direction: column; gap: var(--space-1); }
  .team-card__credentials div { display: flex; gap: var(--space-2); font-size: var(--text-body-sm); }
  .team-card__credentials dt { font-weight: var(--font-semibold); color: var(--color-gray-600); min-width: 60px; }
  .team-card__credentials dd { color: var(--color-gray-400); font-style: italic; }
  .team-card__bio { font-size: var(--text-body-sm); line-height: var(--leading-relaxed); border-top: 1px solid var(--color-gray-100); padding-top: var(--space-3); }
</style>
