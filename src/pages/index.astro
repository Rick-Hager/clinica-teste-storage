---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import StepCard from '../components/StepCard.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MedicalClinic"],
  "name": "Clínica Teste Storage",
  "description": "Cuidado médico humanizado com excelência técnica em São Paulo.",
  "url": "https://clinicatestestorage.com.br",
  "address": { "@type": "PostalAddress", "addressLocality": "São Paulo", "addressCountry": "BR" }
});

const iconUser = `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
const iconCal = `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 16 11 18 15 14"/></svg>`;
const iconShield = `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`;
const iconSteth = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="18" cy="17" r="3"/><path d="M16 17h2"/></svg>`;
const iconPhone = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`;
const iconEnv = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
const iconWave = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`;
const iconFile = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/></svg>`;

const features = [
  { icon: iconUser, title: 'Atendimento humanizado', text: 'Cada consulta é uma conversa real. Nossos profissionais dedicam o tempo necessário para entender sua história e oferecer o melhor cuidado.' },
  { icon: iconCal, title: 'Agendamento sem complicações', text: 'Marque sua consulta pelo site, pelo WhatsApp ou por telefone — em minutos, você tem seu horário confirmado. Sem fila, sem espera desnecessária.' },
  { icon: iconShield, title: 'Medicina baseada em evidências', text: 'Nossa equipe se mantém atualizada com os protocolos mais recentes. Diagnósticos precisos, orientações claras e acompanhamento contínuo.' },
];

const services = [
  { icon: iconSteth, title: 'Consulta de Clínica Geral', text: 'Avaliação completa do seu estado de saúde, diagnóstico de condições agudas e crônicas, solicitação de exames e encaminhamentos quando necessário.', href: '/servicos/consulta-geral' },
  { icon: iconCal, title: 'Check-up Preventivo', text: 'Programa personalizado por faixa etária e histórico clínico. Detecte precocemente condições que, tratadas cedo, têm muito mais eficácia.', href: '/servicos/check-up-preventivo' },
  { icon: iconPhone, title: 'Telemedicina', text: 'Consultas de retorno e acompanhamento no conforto da sua casa. Segura, regularizada e tão eficaz quanto o presencial para os casos indicados.', href: '/servicos/telemedicina' },
  { icon: iconWave, title: 'Acompanhamento de Saúde', text: 'Monitoramento contínuo de condições crônicas como hipertensão, diabetes e dislipidemia. Cuidado longitudinal que faz diferença no longo prazo.', href: '/servicos/acompanhamento' },
  { icon: iconFile, title: 'Exames e Laudos', text: 'Solicitação e acompanhamento de exames com orientação médica especializada. Encaminhamentos para parceiros de referência quando necessário.', href: '/servicos/exames-e-laudos' },
];

const steps = [
  { number: 1, icon: iconPhone, title: 'Escolha o horário', text: 'Acesse o site, o WhatsApp ou ligue para nós. Escolha o serviço e o horário disponível que melhor se encaixa na sua agenda.' },
  { number: 2, icon: iconEnv, title: 'Receba a confirmação', text: 'Você recebe uma confirmação imediata pelo WhatsApp com todos os detalhes da consulta — data, horário e orientações de preparo se necessário.' },
  { number: 3, icon: iconSteth, title: 'Seja bem-vindo(a)', text: 'Chegue tranquilo(a). Nossa equipe está preparada para recebê-lo(a) com atenção e pontualidade.' },
  { number: 4, icon: iconFile, title: 'Acompanhamento pós-consulta', text: 'Receba o resumo da consulta e orientações pelo WhatsApp. Para dúvidas pontuais, nossa equipe está disponível.' },
];
---

<Base
  title="Clínica Teste Storage — Cuidado Médico Humanizado | São Paulo"
  description="Consultas médicas com qualidade e acolhimento em São Paulo. Agendamento online, equipe especializada e atendimento que respeita o seu tempo. Agende pelo site ou WhatsApp."
  schema={schema}
>

  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__deco" aria-hidden="true"></div>
    <div class="hero__deco-2" aria-hidden="true"></div>
    <div class="container hero__content">
      <span class="overline">Cuidado que transforma</span>
      <h1 id="hero-title" class="hero__title">Medicina de excelência,<br>atendimento que realmente escuta</h1>
      <p class="hero__subtitle">Na Clínica Teste Storage, você encontra profissionais dedicados a cuidar da sua saúde com rigor técnico e atenção humanizada. Agendamento prático, sem burocracia.</p>
      <div class="hero__actions">
        <a href="/contato" class="btn btn-primary btn-lg">Agendar Consulta</a>
        <a href="/servicos" class="btn btn-secondary--white btn-lg">Conhecer serviços</a>
      </div>
    </div>
  </section>

  <!-- Diferenciais -->
  <section class="section section--alt" aria-labelledby="features-title">
    <div class="container">
      <SectionHeading
        overline="Por que escolher a Clínica Teste Storage"
        title="Saúde com excelência, experiência com cuidado"
        center={true}
      />
      <div class="grid-3">
        {features.map(f => (
          <FeatureCard icon={f.icon} title={f.title} text={f.text} />
        ))}
      </div>
    </div>
  </section>

  <!-- Serviços -->
  <section class="section" aria-labelledby="services-title">
    <div class="container">
      <SectionHeading
        overline="Nossos serviços"
        title="Como podemos cuidar de você"
        subtitle="Da consulta de rotina ao check-up preventivo personalizado, oferecemos uma linha completa de cuidados médicos para você e sua família."
        center={true}
      />
      <div class="grid-3">
        {services.map(s => (
          <ServiceCard icon={s.icon} title={s.title} text={s.text} href={s.href} />
        ))}
      </div>
      <div class="services__cta">
        <a href="/servicos" class="btn btn-secondary">Ver todos os serviços</a>
      </div>
    </div>
  </section>

  <!-- Como Funciona -->
  <section class="section section--alt" aria-labelledby="steps-title">
    <div class="container">
      <SectionHeading
        overline="Processo"
        title="Cuidar da sua saúde nunca foi tão prático"
        center={true}
      />
      <div class="grid-4">
        {steps.map(s => (
          <StepCard number={s.number} icon={s.icon} title={s.title} text={s.text} />
        ))}
      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="section" aria-labelledby="testimonials-title">
    <div class="container">
      <SectionHeading
        overline="O que nossos pacientes dizem"
        title="Experiências que nos motivam a melhorar sempre"
        center={true}
      />
      <div class="grid-3">
        {[1, 2, 3].map(() => (
          <div class="testimonial-card">
            <div class="testimonial-card__quote" aria-hidden="true">&ldquo;</div>
            <p class="testimonial-card__text placeholder-text">Depoimento em breve — aguardando autorização do paciente conforme normas CFM.</p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar" aria-hidden="true">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <div>
                <p class="testimonial-card__name placeholder-text">Nome, idade</p>
                <p class="testimonial-card__service placeholder-text">Serviço utilizado</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <CTABanner
    title="Sua saúde começa com uma decisão"
    text="Não espere os sintomas aparecerem. Agende uma consulta hoje e dê o primeiro passo para um cuidado de saúde que realmente faz diferença."
    primaryLabel="Agendar Consulta"
    primaryHref="/contato"
    secondaryLabel="Falar pelo WhatsApp"
    secondaryHref="https://wa.me/5511999999999"
  />

</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    background: var(--gradient-hero);
    color: var(--color-white);
    padding: var(--space-24) 0 var(--space-20);
    overflow: hidden;
  }
  .hero__deco {
    position: absolute;
    right: -80px;
    top: 50%;
    transform: translateY(-50%);
    width: 600px;
    height: 600px;
    border-radius: var(--radius-full);
    background: radial-gradient(circle, rgba(52,160,164,0.22) 0%, transparent 68%);
    pointer-events: none;
  }
  .hero__deco-2 {
    position: absolute;
    left: -120px;
    bottom: -80px;
    width: 400px;
    height: 400px;
    border-radius: var(--radius-full);
    background: radial-gradient(circle, rgba(27,79,138,0.4) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }
  .hero .overline { color: var(--color-accent); margin-bottom: var(--space-4); }
  .hero__title {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-white);
    margin-bottom: var(--space-6);
  }
  .hero__subtitle {
    font-size: var(--text-body-lg);
    color: rgba(255,255,255,0.85);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-10);
    max-width: 540px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  /* Services CTA */
  .services__cta {
    text-align: center;
    margin-top: var(--space-10);
  }

  /* Testimonial cards */
  .testimonial-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6) var(--space-6);
    box-shadow: var(--shadow-md);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .testimonial-card__quote {
    position: absolute;
    top: var(--space-4);
    left: var(--space-6);
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--color-secondary);
    line-height: 1;
    opacity: 0.4;
  }
  .testimonial-card__text {
    font-size: var(--text-body-lg);
    color: var(--color-gray-600);
    font-style: italic;
    line-height: var(--leading-loose);
    flex: 1;
  }
  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: auto;
  }
  .testimonial-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--color-gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-400);
    flex-shrink: 0;
  }
  .testimonial-card__name {
    font-weight: var(--font-semibold);
    font-size: var(--text-body-sm);
  }
  .testimonial-card__service {
    font-size: var(--text-caption);
  }

  @media (max-width: 768px) {
    .hero { padding: var(--space-16) 0; }
    .hero__deco { display: none; }
    .hero__title { font-size: var(--text-h1); }
    .hero__actions { flex-direction: column; }
    .hero__actions .btn { width: 100%; justify-content: center; }
  }
</style>
