---
const navLinks = [
  { label: 'Início',   href: '/' },
  { label: 'Sobre',    href: '/sobre' },
  { label: 'Equipe',   href: '/equipe' },
  { label: 'Blog',     href: '/blog' },
  { label: 'Contato',  href: '/contato' },
];

const serviceLinks = [
  { label: 'Consulta de Clínica Geral',  href: '/servicos/consulta-geral' },
  { label: 'Check-up Preventivo',        href: '/servicos/check-up-preventivo' },
  { label: 'Telemedicina',               href: '/servicos/telemedicina' },
  { label: 'Acompanhamento de Saúde',    href: '/servicos/acompanhamento' },
  { label: 'Exames e Laudos',            href: '/servicos/exames-e-laudos' },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <!-- Coluna 1: Brand -->
        <div class="footer__brand">
          <a href="/" class="footer__logo" aria-label="Clínica Teste Storage — Página inicial">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="36" height="36" rx="9" fill="#34A0A4"/>
              <path d="M18 10v16M10 18h16" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <span class="footer__logo-name">Clínica Teste Storage</span>
          </a>
          <p class="footer__tagline">&ldquo;Cuidado que transforma.<br>Tecnologia que facilita.&rdquo;</p>
          <div class="footer__social">
            <a href="#" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
            <a href="https://wa.me/5511999999999" class="footer__social-link" aria-label="WhatsApp" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Coluna 2: Navegação -->
        <nav aria-label="Links do rodapé — Páginas">
          <h3 class="footer__col-title">Navegação</h3>
          <ul class="footer__links">
            {navLinks.map(l => (
              <li><a href={l.href} class="footer__link">{l.label}</a></li>
            ))}
          </ul>
        </nav>

        <!-- Coluna 3: Serviços -->
        <nav aria-label="Links do rodapé — Serviços">
          <h3 class="footer__col-title">Serviços</h3>
          <ul class="footer__links">
            {serviceLinks.map(l => (
              <li><a href={l.href} class="footer__link">{l.label}</a></li>
            ))}
          </ul>
        </nav>

        <!-- Coluna 4: Contato -->
        <div>
          <h3 class="footer__col-title">Contato</h3>
          <ul class="footer__contact">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="placeholder-text">Endereço: a preencher</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 13.5 19.79 19.79 0 0 1 1.08 4.82 2 2 0 0 1 3.08 2.65h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <span class="placeholder-text">Telefone: a preencher</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
              <a href="https://wa.me/5511999999999" class="footer__link" target="_blank" rel="noopener">WhatsApp</a>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span class="placeholder-text">E-mail: a preencher</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span class="placeholder-text">Horários: a preencher</span>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </div>

  <!-- Rodapé inferior -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; 2025 Clínica Teste Storage.
        <span class="placeholder-text"> CRM: a preencher &mdash; Dr(a). a preencher.</span>
      </p>
      <div class="footer__legal">
        <a href="/privacidade" class="footer__legal-link">Política de Privacidade</a>
        <span aria-hidden="true">&bull;</span>
        <a href="/termos" class="footer__legal-link">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gradient-hero);
    color: var(--color-white);
  }
  .footer__main {
    padding: var(--space-16) 0 var(--space-12);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr 1.2fr;
    gap: var(--space-10);
  }

  /* Brand */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .footer__logo-name {
    font-size: 1rem;
    font-weight: var(--font-bold);
    color: var(--color-white);
  }
  .footer__tagline {
    font-size: var(--text-body-sm);
    color: rgba(255,255,255,0.7);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }
  .footer__social {
    display: flex;
    gap: var(--space-3);
  }
  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.8);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color            var(--duration-fast) var(--ease-out);
  }
  .footer__social-link:hover {
    background-color: rgba(255,255,255,0.2);
    color: var(--color-white);
  }
  .footer__social-link:focus-visible { outline: 2px solid rgba(255,255,255,0.5); outline-offset: 2px; }

  /* Columns */
  .footer__col-title {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: var(--space-4);
  }
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .footer__link {
    font-size: var(--text-body-sm);
    color: rgba(255,255,255,0.7);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .footer__link:hover { color: var(--color-white); }

  /* Contact */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-body-sm);
    color: rgba(255,255,255,0.7);
  }
  .footer__contact svg { flex-shrink: 0; margin-top: 1px; }
  .footer__contact .placeholder-text { color: rgba(148,163,184,0.8); }
  .footer__contact .footer__link { color: rgba(255,255,255,0.7); }
  .footer__contact .footer__link:hover { color: var(--color-white); }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: var(--space-6) 0;
  }
  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .footer__copy {
    font-size: var(--text-caption);
    color: rgba(255,255,255,0.5);
  }
  .footer__copy .placeholder-text { color: rgba(148,163,184,0.6); }
  .footer__legal {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-caption);
    color: rgba(255,255,255,0.4);
  }
  .footer__legal-link {
    color: rgba(255,255,255,0.6);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .footer__legal-link:hover { color: var(--color-white); }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }
  @media (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
