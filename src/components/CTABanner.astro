---
export interface Props {
  title: string;
  text: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const { title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---
<section class="cta-banner section--dark">
  <div class="cta-banner__decoration" aria-hidden="true"></div>
  <div class="container cta-banner__content">
    <h2 class="cta-banner__title">{title}</h2>
    <p class="cta-banner__text">{text}</p>
    <div class="cta-banner__actions">
      <a href={primaryHref} class="btn btn-primary btn-lg">{primaryLabel}</a>
      {secondaryLabel && secondaryHref && (
        <a href={secondaryHref} class="btn btn-secondary--white btn-lg">{secondaryLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    text-align: center;
    padding: var(--space-24) 0;
    overflow: hidden;
  }
  .cta-banner__decoration {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 700px;
    border-radius: var(--radius-full);
    background: radial-gradient(circle, rgba(52,160,164,0.15) 0%, transparent 65%);
    pointer-events: none;
  }
  .cta-banner__content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }
  .cta-banner__title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--font-regular);
    color: var(--color-white);
    margin-bottom: var(--space-5);
    line-height: var(--leading-snug);
  }
  .cta-banner__text {
    font-size: var(--text-body-lg);
    color: rgba(255,255,255,0.82);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-10);
  }
  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }
  @media (max-width: 640px) {
    .cta-banner { padding: var(--space-16) 0; }
    .cta-banner__actions { flex-direction: column; align-items: center; }
    .cta-banner__actions .btn { width: 100%; max-width: 320px; justify-content: center; }
  }
</style>
