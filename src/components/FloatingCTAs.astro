---
---
<!-- Botão flutuante WhatsApp (sempre visível) -->
<a
  href="https://wa.me/5511999999999?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20consulta."
  class="fab-whatsapp"
  aria-label="Agendar pelo WhatsApp"
  target="_blank"
  rel="noopener noreferrer"
  role="button"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
  </svg>
</a>

<!-- Barra de CTA mobile (oculta no desktop) -->
<div class="mobile-cta-bar hide-on-desktop" role="region" aria-label="Ações de contato rápido">
  <a href="tel:+5511999999999" class="mobile-cta-bar__btn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 13.5 19.79 19.79 0 0 1 1.08 4.82 2 2 0 0 1 3.08 2.65h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    Ligar agora
  </a>
  <a
    href="https://wa.me/5511999999999?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20consulta."
    class="mobile-cta-bar__btn mobile-cta-bar__btn--whatsapp"
    target="_blank"
    rel="noopener"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    Agendar no WhatsApp
  </a>
</div>

<style>
  /* FAB WhatsApp */
  .fab-whatsapp {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: var(--z-toast);
    width: 56px;
    height: 56px;
    background-color: #25D366;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    color: white;
    transition:
      transform   var(--duration-normal) var(--ease-spring),
      box-shadow  var(--duration-normal) var(--ease-out);
  }
  .fab-whatsapp:hover { transform: scale(1.1); box-shadow: var(--shadow-xl); }
  .fab-whatsapp:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(37,211,102,0.5);
  }

  /* Mobile CTA bar */
  .mobile-cta-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    display: flex;
    background: var(--color-white);
    box-shadow: 0 -2px 12px rgba(26,32,44,0.12);
    border-top: 1px solid var(--color-gray-100);
  }
  .mobile-cta-bar__btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4);
    font-size: var(--text-body-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    background: var(--color-white);
    transition: background-color var(--duration-fast) var(--ease-out);
    min-height: 56px;
    border: none;
    text-decoration: none;
  }
  .mobile-cta-bar__btn:hover { background-color: var(--color-primary-light); }
  .mobile-cta-bar__btn--whatsapp {
    background-color: #25D366;
    color: var(--color-white);
    border-left: 1px solid rgba(255,255,255,0.2);
  }
  .mobile-cta-bar__btn--whatsapp:hover { background-color: #1DAE54; }

  /* Ajuste para o FAB não sobrepor a barra mobile */
  @media (max-width: 1024px) {
    .fab-whatsapp { display: none; }
  }
</style>
